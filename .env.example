# Google Gemini API - FREE tier (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-key-here

# Demo mode — when 'true', skips Gemini and echoes the uploaded image back as the "3D" render.
# Useful for demos without an API key or to avoid quota burn.
MOCK_GEMINI=false

# Clerk Keys (https://dashboard.clerk.com)
CLERK_SECRET_KEY=sk_test_your-key-here
CLERK_PUBLISHABLE_KEY=pk_test_your-key-here

# MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb://127.0.0.1:27017/sketchrise

# Cloudinary (image storage — mirrors the Android app's sketchrise/2d and sketchrise/3d folders)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# CORS - your frontend URL
CORS_ORIGIN=http://localhost:5173

PORT=8080
NODE_ENV=development
